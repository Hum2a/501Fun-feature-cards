{
  "name": "@humza/feature-cards",
  "version": "1.0.1",
  "description": "A CMS-agnostic, accessible, responsive <feature-cards> Web Component with a schema-first adapter layer.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "author": "Humza Butt <Humzab1711@hotmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/humza/feature-cards.git"
  },
  "homepage": "https://501fun.humza-butt.space",
  "bugs": {
    "url": "https://github.com/humza/feature-cards/issues"
  },
  "keywords": [
    "web-component",
    "custom-element",
    "feature-cards",
    "cms-agnostic",
    "accessible",
    "shadow-dom"
  ],
  "sideEffects": false,
  "customElements": "custom-elements.json",
  "main": "./dist/feature-cards.js",
  "module": "./dist/feature-cards.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/feature-cards.js",
      "default": "./dist/feature-cards.js"
    },
    "./iife": "./dist/feature-cards.iife.js",
    "./react": {
      "types": "./dist/types/react/index.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    }
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "files": [
    "custom-elements.json",
    "dist",
    "LICENSE",
    "NOTICE",
    "COPYRIGHT",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build:lib": "vite build && vite build --config vite.react.config.ts && tsc -p tsconfig.build.json && node scripts/generate-cem.mjs",
    "build": "npm run clean && npm run build:lib && vite build --config vite.demo.config.ts",
    "preview": "vite preview --config vite.demo.config.ts",
    "serve:cms": "node scripts/run-wrangler.mjs dev --config worker/wrangler.toml",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:fuzz": "vitest run tests/unit/schema.fuzz.test.ts",
    "test:contracts": "vitest run tests/contracts",
    "test:bench": "vitest bench --run",
    "test:browser": "npm run build:lib && web-test-runner",
    "test:a11y": "playwright test tests/a11y",
    "test:e2e": "playwright test tests/e2e",
    "test:visual": "playwright test tests/visual",
    "test:ci": "npm run typecheck && npm run coverage && npm run test:fuzz && npm run test:contracts && npm run test:a11y && npm run test:e2e && npm run test:visual",
    "coverage": "vitest run --coverage",
    "size": "node scripts/size.mjs",
    "analyze": "vite build --mode analyze",
    "canary:verify": "node scripts/canary.mjs",
    "deploy": "npm run build && npm run deploy:pages && npm run deploy:domain && npm run deploy:worker",
    "deploy:pages": "node scripts/run-wrangler.mjs pages deploy dist/demo --project-name=feature-cards --branch=master",
    "deploy:worker": "node scripts/run-wrangler.mjs deploy --config worker/wrangler.toml --env production && node scripts/attach-worker-domain.mjs",
    "deploy:worker:domain": "node scripts/attach-worker-domain.mjs",
    "deploy:worker:domain:dry": "node scripts/attach-worker-domain.mjs --dry-run",
    "deploy:domain": "node scripts/attach-pages-domain.mjs",
    "deploy:domain:dry": "node scripts/attach-pages-domain.mjs --dry-run",
    "deploy:preview": "node scripts/run-wrangler.mjs pages deploy dist/demo --project-name feature-cards --branch preview",
    "release": "node scripts/run-release.mjs",
    "release:current": "node scripts/run-release.mjs --current",
    "release:package": "node scripts/publish-package.mjs",
    "release:package:dry": "node scripts/publish-package.mjs --dry-run",
    "release:dry-run": "node scripts/run-release.mjs --dry-run --patch",
    "release:full": "node scripts/run-release.mjs --patch --publish",
    "check": "npm run typecheck && npm run lint && npm run test:ci && npm run size",
    "clean": "node scripts/clean.mjs",
    "doctor": "node scripts/doctor.mjs",
    "banner": "node scripts/banner.mjs",
    "stats": "node scripts/stats.mjs",
    "loc": "node scripts/loc.mjs",
    "loc:json": "node scripts/loc.mjs --json",
    "loc:report": "node scripts/loc.mjs --report",
    "ascii": "node scripts/ascii.mjs",
    "whoami": "node scripts/whoami.mjs",
    "coffee": "node scripts/coffee.mjs",
    "ship-it": "node scripts/ship-it.mjs",
    "party": "node scripts/party.mjs",
    "rules:sync": "node scripts/sync-agent-rules.mjs",
    "rules:sync:check": "node scripts/sync-agent-rules.mjs --check",
    "docs:api": "typedoc",
    "cem": "node scripts/generate-cem.mjs",
    "sri": "node scripts/generate-sri.mjs",
    "validate:cms": "node scripts/validate-cms-json.mjs",
    "postinstall": "node scripts/banner.mjs --quiet",
    "prepublishOnly": "npm run build:lib"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^3.23.2",
    "happy-dom": "^15.11.7",
    "msw": "^2.7.0",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "typedoc": "^0.27.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
