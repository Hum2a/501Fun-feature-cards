# Copy to `.env` and fill in values for local development:
#   cp .env.example .env
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# Demo: URL the third <feature-cards> instance tries before the static fixture
VITE_FC_CMS_ENDPOINT=http://localhost:8787/api/cards

# Demo dev server (optional — vite.demo.config.ts defaults to 5173)
VITE_DEV_PORT=5173

# --- Local tooling (not sent to the browser) ---

# npm publish — use `npm login` instead when possible; only for CI/automation
# NPM_TOKEN=

# Cloudflare deploy (`npm run deploy`, wrangler) — also set as GitHub Actions secrets
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# Default target for `npm run canary:verify -- <url>` when no arg is passed (optional)
# CANARY_VERIFY_URL=http://localhost:4173/
